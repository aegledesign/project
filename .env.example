# Copy to .env.local
NEXT_PUBLIC_SITE_NAME="Aegle Custom"
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aegle
ADMIN_API_KEY=replace-with-a-long-random-secret
ADMIN_PASSWORD=replace-with-a-different-strong-password
STRIPE_SECRET_KEY="sk_test_replace_me"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_replace_me"
STRIPE_WEBHOOK_SECRET="whsec_replace_me"

# Optional S3-compatible object storage. Without these, uploads use public/uploads.
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=
S3_PUBLIC_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Optional visual artwork review in the design lab.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_IMAGE_MODEL=gpt-image-1.5
