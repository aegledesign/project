generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MockupView {
  FRONT
  BACK
  LEFT
  RIGHT
  DETAIL
}

enum NavigationLocation {
  HEADER
  FOOTER
}

model MediaAsset {
  id        String          @id @default(cuid())
  url       String
  key       String          @unique
  fileName  String
  mimeType  String
  size      Int
  altText   String          @default("")
  mockups   ProductMockup[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model Product {
  id          String           @id @default(cuid())
  slug        String           @unique
  name        String
  categoryId  String?
  category    String
  description String
  sku         String           @unique
  active      Boolean          @default(true)
  basePrice   Decimal          @db.Decimal(10, 2)
  sizes       String[]
  tags        String[]
  priceBreaks Json
  variants    ProductVariant[]
  mockups     ProductMockup[]
  categoryRef ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model ProductCategory {
  id           String    @id @default(cuid())
  name         String
  slug         String    @unique
  description  String
  imageUrl     String?
  displayOrder Int       @default(0)
  active       Boolean   @default(true)
  products     Product[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model ProductVariant {
  id        String          @id @default(cuid())
  productId String
  colorKey  String
  colorName String
  hexColor  String?
  sku       String?
  active    Boolean         @default(true)
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  mockups   ProductMockup[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([productId, colorKey])
}

model ProductMockup {
  id           String          @id @default(cuid())
  productId    String
  variantId    String?
  mediaAssetId String
  view         MockupView
  colorKey     String
  altText      String
  displayOrder Int             @default(0)
  active       Boolean         @default(true)
  isDefault    Boolean         @default(false)
  product      Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant      ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  mediaAsset   MediaAsset      @relation(fields: [mediaAssetId], references: [id], onDelete: Restrict)
  printAreas   PrintArea[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([productId, colorKey, view])
}

model PrintArea {
  id        String        @id @default(cuid())
  mockupId  String
  label     String
  x         Float
  y         Float
  width     Float
  height    Float
  rotation  Float         @default(0)
  bleed     Float         @default(0)
  active    Boolean       @default(true)
  mockup    ProductMockup @relation(fields: [mockupId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Page {
  id        String        @id @default(cuid())
  slug      String        @unique
  title     String
  active    Boolean       @default(true)
  sections  PageSection[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model PageSection {
  id           String   @id @default(cuid())
  pageId       String
  type         String
  displayOrder Int      @default(0)
  active       Boolean  @default(true)
  content      Json
  page         Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model NavigationItem {
  id           String             @id @default(cuid())
  label        String
  href         String
  location     NavigationLocation
  group        String             @default("")
  displayOrder Int                @default(0)
  active       Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model ThemeSetting {
  id              String   @id @default(cuid())
  key             String   @unique @default("default")
  brandName       String
  logoUrl         String?
  primaryColor    String
  accentColor     String
  backgroundColor String
  footerText      String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Order {
  id           String   @id @default(cuid())
  customerName String
  email        String
  status       String
  total        Float
  notes        String?
  proofStatus  String?
  items        Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Design {
  id            String   @id @default(cuid())
  productSlug   String
  customerEmail String?
  designJson    Json
  previewUrl    String?
  createdAt     DateTime @default(now())
}

model GroupOrder {
  id           String    @id @default(cuid())
  name         String
  closeDate    DateTime?
  status       String    @default("Open")
  instructions String?
  createdAt    DateTime  @default(now())
}
